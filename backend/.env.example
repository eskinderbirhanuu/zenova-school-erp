# === Database ===
DATABASE_URL=postgresql://zenova_user:zenova_pass@localhost:5432/zenova_db

# === Redis (rate limiting, caching, session store) ===
REDIS_URL=redis://localhost:6379/0

# === Security ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
COOKIE_SECURE=false

# === Rate Limiting ===
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=300
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW_SECONDS=60
API_RATE_LIMIT=200
API_RATE_WINDOW_SECONDS=60
BRUTE_FORCE_MAX_PER_IP=20
BRUTE_FORCE_MAX_PER_ID=5
BRUTE_FORCE_LOCKOUT_SECONDS=900

# === Environment ===
ENVIRONMENT=development
BUILD_ID=0

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Super Admin ===
MASTER_SETUP_KEY=
SUPER_ADMIN_PHONE=
SUPER_ADMIN_EMAIL=

# === Network Security ===
# Comma-separated CIDR: "192.168.0.0/16,10.0.0.0/8"
TRUSTED_NETWORKS=

# === Sync ===
# Shared secret for HMAC sync auth between school servers and VPS
SYNC_SECRET=

# === License ===
ZENOVA_LICENSE_KEY=
ZENOVA_LICENSE_SERVER=https://superadmin.free.nf
SCHOOL_ID=
LICENSE_OFFLINE_GRACE_DAYS=45

# === SMTP / Email ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=ZENOVA School
EMAIL_FROM_ADDRESS=noreply@zenova.com

# === Telegram ===
TELEGRAM_WEBHOOK_BASE_URL=

# === Database Connection Pool ===
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# === Backup ===
BACKUP_ENCRYPT_ENABLED=false
BACKUP_ENCRYPTION_KEY=
BACKUP_CLOUD_URL=
BACKUP_CLOUD_ACCESS_KEY=
BACKUP_CLOUD_SECRET_KEY=

# === Archive Retention (days) ===
ARCHIVE_RETENTION_ATTENDANCE_DAYS=730
ARCHIVE_RETENTION_NOTIFICATIONS_DAYS=180
ARCHIVE_RETENTION_AUDIT_LOGS_DAYS=365
ARCHIVE_RETENTION_SYNC_QUEUE_DAYS=90
