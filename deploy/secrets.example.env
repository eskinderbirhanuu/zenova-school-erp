# ZENOVA Production Secrets Template
# Copy to secrets.env and fill all values before deploying.
# NEVER commit this file to version control.

# --- Core Security ---
# Generate with: openssl rand -base64 48
SECRET_KEY=change-me-to-a-random-64-char-string
# Generate with: openssl rand -base64 24
MASTER_SETUP_KEY=change-me-to-a-random-32-char-string

# --- Database ---
DATABASE_URL=postgresql://zenova_user:STRONG_PASSWORD@zenova-db:5432/zenova_db

# --- Redis (set same password in REDIS_PASSWORD) ---
REDIS_URL=redis://:STRONG_REDIS_PASSWORD@zenova-redis:6379/0
REDIS_PASSWORD=STRONG_REDIS_PASSWORD

# --- SMTP (optional for email notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@zenova.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_NAME=ZENOVA School
EMAIL_FROM_ADDRESS=noreply@zenova.com

# --- License Server ---
LICENSE_SERVER_URL=https://license.zenova.example.com
LICENSE_API_KEY=your-license-server-api-key
# For production, license-server should use PostgreSQL:
# LICENSE_DATABASE_URL=postgresql://zenova:STRONG_PASSWORD@license-db:5432/zenova_license

# --- License Signing Private Key (base64-encoded PEM) ---
# Generate with: base64 -w0 backend/keys/license_private.pem
# In production, store this in a secrets manager; NEVER in the repo.
LICENSE_PRIVATE_KEY=

# --- Chapa Payment Gateway (optional) ---
FEATURE_CHAPA=false
CHAPA_SECRET_KEY=your-chapa-secret-key
CHAPA_PUBLIC_KEY=your-chapa-public-key
