# ZENOVA Docker Environment Variables
# Copy this to .env and adjust for your setup

# Database
DATABASE_URL=postgresql://zenova_user:zenova_pass@db:5432/zenova_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ENVIRONMENT=development

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# SMTP (optional — leave empty to skip emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=ZENOVA School
EMAIL_FROM_ADDRESS=noreply@zenova.com
